            const errorBody = await response.text();
            exa_log.extend('error')(`Exa request failed with status ${response.status}: %s`, errorBody.length > 200 ? `${errorBody.slice(0, 200)}...` : errorBody);
            throw new tracked_DBSMdVzR/* TRPCError */.gt({
                cause: errorBody,
                code: 'SERVICE_UNAVAILABLE',
                message: `Exa request failed: ${response.statusText}`
            });
        }
        try {
            const exaResponse = await response.json();
            exa_log('Parsed Exa response: %o', exaResponse);
            const mappedResults = (exaResponse.results || []).map((result)=>({
                    category: body.category || 'general',
