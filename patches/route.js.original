            'search1api'
        ],
        urlPattern: 'https://www.youtube.com/watch(.*)'
    },
    // Reddit 链接，使用 search1api，格式化 markdown，包含标题、作者、互动数量、具体评论内容等
    {
        impls: [
            'search1api'
        ],
        urlPattern: 'https://www.reddit.com/r/(.*)/comments/(.*)'
    },
    // 微信公众号有爬虫防护，优先使用 search1api，jina 作为兜底（目前 jina 爬取会被风控）
    {
        impls: [
