        configSchema.properties && Object.values(configSchema.properties).some((prop)=>prop.required === true)));
        MCPSystemDepsCheckService_log(`Configuration check result: needsConfig=${needsConfig}, required=${configSchema?.required}, configSchema=%O`, configSchema);
        // Create connection info
        const connection = option.connection.url ? {
            ...option.connection,
            type: 'http'
        } : {
            ...option.connection,
            type: 'stdio'
        };
        return {
            allDependenciesMet,
            configSchema,
            connection,
            isRecommended: option.isRecommended,
            needsConfig,
            packageInstalled,
            systemDependencies: systemDependenciesResults
        };
    }
