                const requirementMatch = dependency.requiredVersion.match(/([<=>]+)?(\d+(\.\d+)*)/);
                if (requirementMatch) {
                    const [, operator = '=', requiredVersion] = requirementMatch;
                    const requiredNum = parseFloat(requiredVersion);
                    switch(operator){
                        case '>=':
                            {
                                meetRequirement = currentVersionNum >= requiredNum;
                                break;
                            }
                        case '>':
                            {
                                meetRequirement = currentVersionNum > requiredNum;
                                break;
                            }
                        case '<=':
                            {
                                meetRequirement = currentVersionNum <= requiredNum;
                                break;
                            }
                        case '<':
                            {
                                meetRequirement = currentVersionNum < requiredNum;
                                break;
