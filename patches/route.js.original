/**
 * Exa implementation of the search service
 * Primarily used for web crawling
 */ class ExaImpl {
    get apiKey() {
        return process.env.EXA_API_KEY;
    }
    get baseUrl() {
        // Assuming the base URL is consistent with the crawl endpoint
        return 'https://api.exa.ai';
    }
    async query(query, params = {}) {
        exa_log('Starting Exa query with query: "%s", params: %o', query, params);
        const endpoint = (0,url_join/* default */.A)(this.baseUrl, '/search');
        const defaultQueryParams = {
            numResults: 15,
            query,
            type: 'auto'
        };
        let body = {
            ...defaultQueryParams,
            ...params?.searchTimeRange && params.searchTimeRange !== 'anytime' ? (()=>{
                const now = Date.now();
                const days = {
                    day: 1,
                    month: 30,
                    week: 7,
                    year: 365
                }[params.searchTimeRange];
                if (days === undefined) return {};
                return {
                    endPublishedDate: new Date(now).toISOString(),
                    startPublishedDate: new Date(now - days * 86400 * 1000).toISOString()
                };
            })() : {},
            category: params?.searchCategories?.filter((cat)=>[
                    'news'
                ].includes(cat))?.[0]
        };
        exa_log('Constructed request body: %o', body);
        let response;
        const startAt = Date.now();
        let costTime = 0;
        try {
            exa_log('Sending request to endpoint: %s', endpoint);
            response = await fetch(endpoint, {
                body: JSON.stringify(body),
                headers: {
                    'Content-Type': 'application/json',
                    'x-api-key': this.apiKey ? this.apiKey : ''
                },
                method: 'POST'
            });
            exa_log('Received response with status: %d', response.status);
            costTime = Date.now() - startAt;
        } catch (error) {
            exa_log.extend('error')('Exa fetch error: %o', error);
            throw new tracked_DBSMdVzR/* TRPCError */.gt({
                cause: error,
                code: 'SERVICE_UNAVAILABLE',
                message: 'Failed to connect to Exa.'
            });
        }
