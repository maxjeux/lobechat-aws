# Lobe Chat Configuration
# Generate with: openssl rand -base64 32
KEY_VAULTS_SECRET=your-key-vaults-secret-min-32-chars
NEXT_AUTH_SECRET=your-nextauth-secret-min-32-chars

# Casdoor SSO Configuration
AUTH_CASDOOR_ISSUER=http://localhost:47002
AUTH_CASDOOR_ID=your-casdoor-app-id
AUTH_CASDOOR_SECRET=your-casdoor-app-secret

# S3 Storage Configuration for Lobe Chat
S3_ENDPOINT=http://localhost:47005
S3_PUBLIC_DOMAIN=http://localhost:47005
S3_BUCKET=lobe

# PostgreSQL Configuration
POSTGRES_PASSWORD=change-me-postgres
LITELLM_DB_PASSWORD=change-me-litellm
LOBE_DB_PASSWORD=change-me-lobechat

# MinIO S3 Storage Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
